# ============================================================
# SERVER ENVIRONMENT TEMPLATE — safe to commit
# Copy to .env and fill in real values
# ============================================================

NODE_ENV=development
PORT=3001

# Hostinger MySQL connection string
# Host: hPanel → Databases → MySQL → Remote MySQL hostname
DATABASE_URL="mysql://DB_USER:DB_PASSWORD@DB_HOST:3306/DB_NAME?connection_limit=10&pool_timeout=20"

# JWT secrets — generate with:
# node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
ACCESS_TOKEN_SECRET=
REFRESH_TOKEN_SECRET=

# Frontend origin for CORS
CORS_ORIGIN=http://localhost:5173
